# --- Required ---
DATABASE_URL="postgresql://admin:admin@db:5432/cron_mcp"

NEXTAUTH_SECRET="CHANGE_ME"                       # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3015"
PUBLIC_BASE_URL="http://localhost:3015"           # https://... in prod

# --- Sign-in providers (add any subset; unset providers are hidden) ---

# Google — https://console.cloud.google.com/apis/credentials
# Redirect: <PUBLIC_BASE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/applications/new
# Callback: <PUBLIC_BASE_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Scheduler ---

# How many seconds between fire-loop passes. 60 is plenty for typical cron
# expressions; drop lower only if you need sub-minute schedules.
SCHEDULER_TICK_SECONDS="60"

# HMAC secret used to sign outbound webhook calls to the user's callback URL.
# Callback receivers should verify by re-hashing the raw body with this key
# and comparing against the X-Cron-Signature header. Rotate as needed.
CRON_WEBHOOK_SIGNING_SECRET=""

# --- No LLM required ---
# This service does not do inference. Your agent supplies its own model.
